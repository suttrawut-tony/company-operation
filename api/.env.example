# ═══ SDA Operation — Environment Variables ═══
# Copy to .env and fill in values

# Server
PORT=4000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/sda_operation

# JWT Auth
JWT_SECRET=your-secret-key-change-this
JWT_EXPIRES_IN=7d

# SAP B1 Service Layer
SAP_BASE_URL=https://your-sap-server:50000/b1s/v1
SAP_COMPANY_DB=SDA_PROD
SAP_USERNAME=
SAP_PASSWORD=

# Notification
DISCORD_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@sda-group.com
