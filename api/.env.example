# ═══ Company Operation — Environment Variables ═══
# Copy to .env and fill in values

# Server
PORT=4000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/sda_operation

# JWT Auth — REQUIRED. Must be at least 32 chars and NOT the placeholder below.
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CHANGE-ME-must-be-at-least-32-chars
JWT_EXPIRES_IN=7d
JWT_EXPIRES_REMEMBER=30d
JWT_EXPIRES_SHORT=1d

# Frontend base URL — used in password-reset email links
APP_URL=http://localhost:4000

# CORS origin (use the deployed frontend URL in production)
CORS_ORIGIN=*

# SMTP for forgot-password emails. Leave SMTP_HOST blank to print reset URL to server log.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@sda-group.com

# Feature flags
FEATURE_GOOGLE_SSO=false

# Self-register: comma-separated email domain whitelist (e.g. "sala-daeng.com,sda-group.com")
# Leave blank to allow any domain.
REGISTER_ALLOWED_DOMAINS=

# Self-register approval gate. Set to true if you want self-registered users to start
# inactive and require an admin to click "Approve" before they can sign in.
# Default false = users can sign in immediately after registering.
REQUIRE_REGISTER_APPROVAL=false

# Role assigned to users who sign up via /register.
# Default 'staff' for production (least privilege).
# For POC demos, set to 'executive' so new accounts can see the seeded data
# without first being added as a project member.
# Valid: staff, pm, executive, finance, accounting, procurement, admin
REGISTER_DEFAULT_ROLE=staff

# ── Static (no-DB) login ─────────────────────────────────────
# When BOTH of these are set, this one credential pair lets you log in
# without the database being reachable. The session has executive role
# but pages that fetch data from the DB still need the DB to be up.
# Useful for first deploys when Postgres isn't connected yet.
# LEAVE BLANK in production once DB-backed users exist.
STATIC_LOGIN_EMAIL=
STATIC_LOGIN_PASSWORD=
STATIC_LOGIN_NAME=Admin

# ── SAP B1 Service Layer (REST) ──────────────────────────────
# All four must be set for pushes to reach SAP. If any is blank, isConfigured()
# is false and journal pushes are SKIPPED (logged as a warning, not an error).
# Full base URL INCLUDING /b1s/v1. Use the B1 application user (e.g. "manager"),
# NOT the HANA SYSTEM account.
SAP_BASE_URL=https://your-sap-server:50000/b1s/v1
SAP_COMPANY_DB=SDA_PROD
SAP_USERNAME=
SAP_PASSWORD=
# TLS: leave unset/false to verify the SAP server certificate (recommended).
# Set to "true" ONLY for a trusted internal SAP host with a self-signed cert.
# This disables cert verification (MITM risk) and requires the "undici" package
# (`npm install undici`). In production, pin the SAP CA instead.
SAP_INSECURE_TLS=false

# Notification
DISCORD_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@sda-group.com
